{
  "name": "db-connect",
  "private": true,
  "version": "1.0.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "icons:sync": "tauri icon src-tauri/icons/icon.png -o src-tauri/icons",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "fmt:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "release": "node scripts/release.mjs",
    "test:release": "node --test scripts/release-utils.node-test.mjs scripts/release-flow.node-test.mjs scripts/release-notes-utils.node-test.mjs scripts/release-drafter-config.node-test.mjs",
    "audit:rust": "cd src-tauri && cargo audit",
    "audit:npm": "npm audit",
    "audit:secrets": "gitleaks detect --source . --config .gitleaks.toml --verbose",
    "clean": "rm -rf node_modules/.vite dist src-tauri/target",
    "clean:all": "rm -rf node_modules dist src-tauri/target",
    "reset": "rm -rf node_modules dist src-tauri/target && npm install"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@types/react-resizable": "^3.0.8",
    "antd": "^5.22.0",
    "mermaid": "^10.9.5",
    "monaco-editor": "^0.55.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable": "^3.1.3",
    "sql-formatter": "^15.8.2",
    "write-excel-file": "^4.0.7",
    "zustand": "^5.0.0"
  },
  "overrides": {
    "dompurify": "^3.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^25.0.0",
    "prettier": "^3.8.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.16",
    "vitest": "^4.0.18"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}

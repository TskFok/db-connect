# 复制为 .env 后按需修改（.env 已在 .gitignore 中，不会提交）
# cp .env.example .env

# ---------------------------------------------------------------------------
# 前端构建变量（Vite，需 VITE_ 前缀才会注入 import.meta.env）
# ---------------------------------------------------------------------------

# 崩溃上报默认 GitHub 仓库，格式：owner/repo
# 未设置时使用 src/utils/crashReport.ts 中的 DEFAULT_GITHUB_REPO
# VITE_GITHUB_ISSUE_REPO=your-org/your-repo

# ---------------------------------------------------------------------------
# 开发 / 打包（通常由 Tauri CLI 自动注入，一般无需手动配置）
# ---------------------------------------------------------------------------

# Tauri 开发模式下的 HMR 主机（npm run tauri dev 时由 CLI 设置）
# TAURI_DEV_HOST=
